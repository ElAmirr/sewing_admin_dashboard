{
  "name": "sewing_admin_dashboard",
  "version": "1.0.0",
  "description": "sewing_admin_dashboard",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run electron:dev\" \"npm run frontend:dev\"",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "electron:dev": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "frontend:dev": "cd frontend && npm run dev",
    "electron:build": "npm run frontend:build && electron-builder",
    "frontend:build": "cd frontend && npm run build"
  },
  "type": "commonjs",
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mysql2": "^3.10.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.sewing.admin",
    "productName": "SewingAdminDashboard",
    "asar": true,
    "asarUnpack": [
      "backend/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "package.json"
    ],
    "extraFiles": [
      "setting.json",
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": "AppImage"
    }
  }
}